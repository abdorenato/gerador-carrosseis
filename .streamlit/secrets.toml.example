# EXEMPLO de secrets.toml para o Growth Studio
#
# Este arquivo serve apenas como referência.
# O arquivo real é .streamlit/secrets.toml (não commitado, está no .gitignore)
# No Streamlit Cloud, cole esse conteúdo em "Advanced settings → Secrets"

# ── Claude / Anthropic ──────────────────────────────────────────────────────
CLAUDE_API_KEY = "sk-ant-api03-SUA-KEY-AQUI"
CLAUDE_MODEL = "claude-haiku-4-5-20251001"

# ── Google Sheets (captação de leads) ───────────────────────────────────────
LEADS_SHEET_URL = "https://docs.google.com/spreadsheets/d/SEU-SHEET-ID-AQUI/edit"

# Credenciais da Service Account do Google Cloud
# Cole o conteúdo do arquivo JSON baixado em "APIs → Credenciais → Conta de serviço"
[gcp_service_account]
type = "service_account"
project_id = "growth-studio"
private_key_id = "xxx"
private_key = "-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"
client_email = "growth-studio-bot@growth-studio.iam.gserviceaccount.com"
client_id = "XXXX"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/growth-studio-bot%40growth-studio.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
